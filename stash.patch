+function normalizeServiceType(value) {
+  return String(value || '').trim().toLowerCase()
+}
+
+function isTrackedServiceType(value) {
+  const normalizedValue = normalizeServiceType(value)
+  return trackedServiceTypes.some((type) => normalizeServiceType(type) === normalizedValue)
+}
+
+function parseServiceOdometerFromNotes(notes = '') {
+  const match = String(notes).match(serviceOdometerPattern)
+  if (!match) return null
+
+  const parsedOdometer = Number(match[1].replace(/,/g, ''))
+  return Number.isFinite(parsedOdometer) ? parsedOdometer : null
+}
+
+function stripServiceOdometerMarker(notes = '') {
+  return String(notes).replace(serviceOdometerPattern, '\n').replace(/\n{3,}/g, '\n\n').trim()
+}
+
+function withServiceOdometerNote(notes, odometer) {
+  const cleanedNotes = stripServiceOdometerMarker(notes)
+  const marker = `Service odometer: ${Number(odometer).toLocaleString()} KM`
+  return cleanedNotes ? `${cleanedNotes}\n${marker}` : marker
+}
+
+function getCurrentOdometerByVehicle(fuelLogs) {
+  return fuelLogs.reduce((odometerByVehicle, fuelLog) => {
+    const odometerReading = Number(fuelLog.odometerReading)
+    if (!fuelLog.vehicleId || !Number.isFinite(odometerReading)) return odometerByVehicle
+
+    const currentOdometer = odometerByVehicle[fuelLog.vehicleId]
+    if (currentOdometer === undefined || odometerReading > currentOdometer) {
+      odometerByVehicle[fuelLog.vehicleId] = odometerReading
+    }
+
+    return odometerByVehicle
+  }, {})
+}
+
+function getMaintenanceSortValue(record) {
+  const dateValue = record.updatedAt || record.createdAt || record.nextServiceDate || record.reminderDate
+  const parsedDate = new Date(dateValue).getTime()
+  return Number.isFinite(parsedDate) ? parsedDate : 0
+}
+
+function getLatestCompletedServiceRecord(records, vehicleId, serviceType) {
+  return records
+    .filter(
+      (record) =>
+        record.vehicleId === vehicleId &&
+        record.status === 'Completed' &&
+        normalizeServiceType(record.serviceType) === normalizeServiceType(serviceType) &&
+        parseServiceOdometerFromNotes(record.notes) !== null,
+    )
+    .sort((firstRecord, secondRecord) => getMaintenanceSortValue(secondRecord) - getMaintenanceSortValue(firstRecord))[0]
+}
+
+function parseDateOnly(value) {
+  if (!value) return null
+
+  const dateValue = typeof value === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(value) ? value : toDateInputValue(value)
+  const [year, month, day] = dateValue.split('-').map(Number)
+  if (!year || !month || !day) return null
+
+  const parsedDate = new Date(year, month - 1, day)
+  return Number.isNaN(parsedDate.getTime()) ? null : parsedDate
+}
+
+function getTodayDateOnly() {
+  const today = new Date()
+  today.setHours(0, 0, 0, 0)
+  return today
+}
+
+function getDaysUntil(value) {
+  const date = parseDateOnly(value)
+  if (!date) return null
+
+  const millisecondsInDay = 1000 * 60 * 60 * 24
+  return Math.ceil((date.getTime() - getTodayDateOnly().getTime()) / millisecondsInDay)
+}
+
+function formatDate(value) {
+  const date = parseDateOnly(value)
+  if (!date) return 'Not set'
+
+  return date.toLocaleDateString(undefined, {
+    day: 'numeric',
+    month: 'short',
+    year: 'numeric',
+  })
+}
+
+function getDocumentReminderStatus(expiryDate) {
+  const daysUntil = getDaysUntil(expiryDate)
+  if (daysUntil === null) return null
+  if (daysUntil < 0) return { label: 'Expired', tone: 'danger', daysUntil }
+  if (daysUntil <= documentReminderDays) return { label: 'Upcoming', tone: 'warning', daysUntil }
+  return null
+}
+
+function getDocumentReminderDetail(daysUntil) {
+  if (daysUntil < 0) {
+    const daysExpired = Math.abs(daysUntil)
+    return daysExpired === 1 ? 'Expired 1 day ago' : `Expired ${daysExpired} days ago`
+  }
+
+  if (daysUntil === 0) return 'Expires today'
+  return daysUntil === 1 ? 'Expires in 1 day' : `Expires in ${daysUntil} days`
+}
+
+function getMaintenanceDateLabel(serviceType) {
+  if (normalizeServiceType(serviceType) === normalizeServiceType('Oil Change')) return 'Oil change date'
+  if (normalizeServiceType(serviceType) === normalizeServiceType('Tyre Replacement')) return 'Replacement date'
+  return 'Next service date'
+}
+
+function buildServiceReminderRows(vehicles, fuelLogs, maintenanceRecords) {
+  const currentOdometerByVehicle = getCurrentOdometerByVehicle(fuelLogs)
+
+  return vehicles.flatMap((vehicle) =>
+    trackedServiceTypes.map((serviceType) => {
+      const vehicleId = getRecordId(vehicle)
+      const currentOdometer = currentOdometerByVehicle[vehicleId]
+      const latestService = getLatestCompletedServiceRecord(maintenanceRecords, vehicleId, serviceType)
+      const serviceOdometer = latestService ? parseServiceOdometerFromNotes(latestService.notes) : null
+
+      if (currentOdometer === undefined) {
+        return {
+          id: `${vehicleId}-${serviceType}`,
+          vehicleId,
+          vehicleName: vehicle.unit,
+          serviceType,
+          currentOdometer: null,
+          lastServiceOdometer: serviceOdometer,
+          distanceSinceService: null,
+          status: 'Odometer Needed',
+          tone: 'warning',
+          detail: 'Add a fuel log with odometer reading.',
+        }
+      }
+
+      if (serviceOdometer === null) {
+        return {
+          id: `${vehicleId}-${serviceType}`,
+          vehicleId,
+          vehicleName: vehicle.unit,
+          serviceType,
+          currentOdometer,
+          lastServiceOdometer: null,
+          distanceSinceService: null,
+          status: 'Baseline Needed',
+          tone: 'neutral',
+          detail: 'Record a completed service to start tracking.',
+        }
+      }
+
+      const distanceSinceService = Math.max(0, currentOdometer - serviceOdometer)
+      const isDue = distanceSinceService >= serviceIntervalKm
+
+      return {
+        id: `${vehicleId}-${serviceType}`,
+        vehicleId,
+        vehicleName: vehicle.unit,
+        serviceType,
+        currentOdometer,
+        lastServiceOdometer: serviceOdometer,
+        distanceSinceService,
+        status: isDue ? 'Service Due' : 'OK',
+        tone: isDue ? 'danger' : 'success',
+        detail: isDue ? `${distanceSinceService.toLocaleString()} KM since last service.` : `${(serviceIntervalKm - distanceSinceService).toLocaleString()} KM remaining.`,
+      }
+    }),
+  )
+}
+
+function buildComplianceReminderRows(vehicles) {
+  return vehicles.flatMap((vehicle) =>
+    [
+      { type: 'Insurance', expiryDate: vehicle.insuranceExpiry },
+      { type: 'Permit', expiryDate: vehicle.permitExpiry },
+    ]
+      .map((document) => {
+        const reminderStatus = getDocumentReminderStatus(document.expiryDate)
+        if (!reminderStatus) return null
+
+        return {
+          id: `${getRecordId(vehicle)}-${document.type}`,
+          vehicleName: vehicle.unit,
+          documentType: document.type,
+          expiryDate: document.expiryDate,
+          status: reminderStatus.label,
+          tone: reminderStatus.tone,
+          detail: getDocumentReminderDetail(reminderStatus.daysUntil),
+        }
+      })
+      .filter(Boolean),
+  )
+}
